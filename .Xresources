! COLOR SCHEME
! black > red > green > yellow > blue > magenta > cyan > white
#define black0                    #373E4D
#define black1                    #3B4252
#define black2                    #434C5E
#define black3                    #4C566A
#define red0                      #FA5AA4
#define red1                      #FA74B2
#define green0                    #2BE491
#define green1                    #44EB9F
#define yellow0                   #FA946E
#define yellow1                   #FAA687
#define blue0                     #63C5EA
#define blue1                     #7ACBEA
#define magenta0                  #643D97
#define magenta1                  #643D97
#define cyan0                     #89CCF7
#define cyan1                     #A1D5F7
#define white0                    #F9F9F9
#define white1                    #F7F7F7
#define white2                    #F4F4F4
#define bg			  #161616

*.color1:                         red0
*.color2:                         green0
*.color3:                         yellow0
*.color4:                         magenta0
*.color5:                         blue0
*.color6:                         cyan0

*.color9:                         red1
*.color10:                        green1
*.color11:                        yellow1
*.color12:                        magenta1
*.color13:                        blue1
*.color14:                        cyan1 

! ST
*font:				  JetBrainsMono Nerd Font:pixelsize=12:antialias=true:autohint=true
*background:			  bg
*borderpx:			  10
